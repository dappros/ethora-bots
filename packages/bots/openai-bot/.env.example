# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Bot configuration file path (optional)
# If not specified, defaults to config/test-bots.json
BOT_CONFIG_FILE=./config/test-bots.json

# Enable API Server
ENABLE_API=false

# API Server Configuration (required if ENABLE_API=true)
API_PORT=3000
API_HOST=localhost

# Authentication for API endpoints (required if ENABLE_API=true)
API_SECRET_KEY=your_secret_key_here