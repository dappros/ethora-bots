  "repository": {
    "type": "git",
    "url": "git+https://github.com/dappros/ethora-bots.git"
  },
  "bugs": {
    "url": "https://github.com/dappros/ethora-bots/issues"
  },
  "homepage": "https://github.com/dappros/ethora-bots#readme",
  "dependencies": {
    "@xmpp/client": "^0.13.4",
    "@xmpp/debug": "^0.13.3",
    "@xmpp/sasl-plain": "^0.13.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.3",
    "@types/xmpp__client": "^0.13.3",
    "@types/xmpp__debug": "^0.13.3",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
